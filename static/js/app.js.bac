// 主题切换
const THEME_CLASSES = ['theme-pink', 'theme-dark-teal', 'theme-dark-pink'];

function setTheme(theme) {
    const root = document.documentElement;
    
    THEME_CLASSES.forEach(cls => root.classList.remove(cls));
    
    if (theme === 'pink') {
        root.classList.add('theme-pink');
    } else if (theme === 'dark-teal') {
        root.classList.add('theme-dark-teal');
    } else if (theme === 'dark-pink') {
        root.classList.add('theme-dark-pink');
    }
    
    localStorage.setItem('blossom-theme', theme);
    updateThemeOptions();
}

function updateThemeOptions() {
    const currentTheme = localStorage.getItem('blossom-theme') || 'green';
    const options = document.querySelectorAll('.theme-card');
    
    options.forEach(opt => opt.classList.remove('active'));
    
    const target = document.querySelector(`.theme-card[data-theme="${currentTheme}"]`);
    if (target) {
        target.classList.add('active');
    } else {
        document.querySelector('.theme-card[data-theme="green"]')?.classList.add('active');
    }
}

function loadSavedTheme() {
    const savedTheme = localStorage.getItem('blossom-theme');
    if (savedTheme) {
        setTheme(savedTheme);
    } else {
        updateThemeOptions();
    }
}

// 布局保存
function saveLayout() {
    const cards = document.querySelectorAll('.dashboard-card');
    const layout = [];
    
    cards.forEach((card, index) => {
        const id = card.dataset.id;
        const size = card.dataset.size;
        const width = card.style.width || '';
        const height = card.style.height || '';
        const gridColumn = card.style.gridColumn || '';
        const gridRow = card.style.gridRow || '';
        
        layout.push({
            id,
            index,
            size,
            width,
            height,
            gridColumn,
            gridRow
        });
    });
    
    localStorage.setItem('blossom-layout', JSON.stringify(layout));
}

function loadSavedLayout() {
    const savedLayout = localStorage.getItem('blossom-layout');
    if (!savedLayout) return;
    
    try {
        const layout = JSON.parse(savedLayout);
        layout.forEach(item => {
            const card = document.querySelector(`[data-id="${item.id}"]`);
            if (card) {
                if (item.size) {
                    card.dataset.size = item.size;
                    const [cols, rows] = item.size.split('x').map(Number);
                    // 验证尺寸是否有效
                    if (cols >= 1 && cols <= 4 && rows >= 1 && rows <= 4) {
                        card.style.gridColumn = `span ${cols}`;
                        card.style.gridRow = `span ${rows}`;
                    }
                }
            }
        });
    } catch (e) {
        console.error('Failed to load layout:', e);
        // 如果加载失败，清除缓存
        localStorage.removeItem('blossom-layout');
    }
}

function resetLayout() {
    localStorage.removeItem('blossom-layout');
    location.reload();
}

// ========== 文章页面功能 ==========

// 当前选中的文件路径
let currentFilePath = '';
let pendingOpenInEdit = false;

// 收藏管理
function getFavorites() {
    try {
        const data = localStorage.getItem('zssnote-favorites');
        console.log('[Favorites] getFavorites:', data);
        return JSON.parse(data || '[]');
    } catch (e) { 
        console.error('[Favorites] getFavorites error:', e);
        return []; 
    }
}

function saveFavorites(list) {
    localStorage.setItem('zssnote-favorites', JSON.stringify(list));
    console.log('[Favorites] saveFavorites:', JSON.stringify(list));
}

function isFavorited(filePath) {
    const result = getFavorites().some(f => f.path === filePath);
    console.log('[Favorites] isFavorited:', filePath, result);
    return result;
}

function toggleFavorite(filePath, title, folderPath) {
    console.log('[Favorites] toggleFavorite called:', { filePath, title, folderPath });
    let list = getFavorites();
    const idx = list.findIndex(f => f.path === filePath);
    if (idx >= 0) {
        list.splice(idx, 1);
        console.log('[Favorites] Removed from favorites');
    } else {
        list.push({ path: filePath, title: title, folderPath: folderPath || '' });
        console.log('[Favorites] Added to favorites');
    }
    saveFavorites(list);
    // 更新菜单栏按钮状态
    updateFavoriteBtn();
    // 更新首页收藏卡片
    renderFavoritesCard();
    return idx < 0; // true = 已收藏, false = 已取消
}

// 更新收藏按钮状态
function updateFavoriteBtnState(btn) {
    if (!btn) return;
    if (!currentFilePath) {
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
        btn.title = '请先选择文档';
        btn.disabled = true;
        return;
    }
    btn.disabled = false;
    const favorited = isFavorited(currentFilePath);
    btn.innerHTML = favorited 
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#FFD700" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
    btn.title = favorited ? '取消收藏' : '收藏文档';
}

// 更新菜单栏收藏按钮
function updateFavoriteBtn() {
    const btn = document.getElementById('article-fav-btn');
    if (btn) {
        updateFavoriteBtnState(btn);
    }
}

// 获取当前文档信息
function getCurrentDocInfo() {
    const titleEl = document.querySelector('.md-h1-wrapper h1');
    const title = titleEl ? titleEl.textContent : currentFilePath.split(/[\\/]/).pop().replace(/\.md$/i, '');
    
    // 获取文件夹路径
    let folderPath = '';
    if (currentFilePath) {
        const sep = currentFilePath.includes('\\') ? '\\' : '/';
        folderPath = currentFilePath.substring(0, currentFilePath.lastIndexOf(sep));
    }
    
    return { title, folderPath };
}

// 渲染首页收藏卡片
function renderFavoritesCard() {
    const container = document.querySelector('.article-stars-root');
    if (!container) return;
    
    const favorites = getFavorites();
    
    if (favorites.length === 0) {
        container.innerHTML = `
            <div style="padding: 20px; text-align: center; color: var(--color-muted); font-size: 13px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 8px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <p>暂无收藏文档</p>
            </div>
        `;
        return;
    }
    
    container.innerHTML = '';
    
    favorites.forEach(fav => {
        const fileName = fav.path.split(/[\\/]/).pop();
        
        const card = document.createElement('div');
        card.className = 'star-card';
        card.dataset.path = fav.path;
        card.innerHTML = `
            <div class="counterfoil">
                <img src="/static/emoji/Page facing up_3d.png" class="emoji-icon" />
            </div>
            <div class="content">
                <div class="name">${escapeHtml(fav.title)}</div>
                <div class="infos">
                    <span>${fileName}</span>
                </div>
            </div>
        `;
        
        card.addEventListener('click', function() {
            openFavorite(fav.path);
        });
        
        container.appendChild(card);
    });
}

// 打开收藏的文档
function openFavorite(filePath) {
    console.log('[Favorites] openFavorite called:', filePath);
    
    // 检查是否在首页（home.html），如果是则跳转到文章页面
    const isHomePage = !document.getElementById('view-article');
    if (isHomePage) {
        console.log('[Favorites] On home page, redirecting to article page');
        // 跳转到文章页面，并传递文件路径参数
        window.location.href = `/article?path=${encodeURIComponent(filePath)}`;
        return;
    }
    
    // 在文章页面，直接加载文章
    if (typeof loadArticle === 'function') {
        loadArticle(filePath);
        switchView('article');
    }
}

// 刷新文档树

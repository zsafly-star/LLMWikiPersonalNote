function showNoteForm(note = null) {
    const modal = document.getElementById('modal-note');
    if (!modal) return;

    const modalTitle = document.getElementById('modal-title');
    const noteId = document.getElementById('note-id');
    const noteTitle = document.getElementById('note-title');
    const noteContent = document.getElementById('note-content');

    if (note) {
        if (modalTitle) modalTitle.textContent = '编辑笔记';
        if (noteId) noteId.value = note.id;
        if (noteTitle) noteTitle.value = note.title || '';
        if (noteContent) noteContent.value = note.content || '';
    } else {
        if (modalTitle) modalTitle.textContent = '新建笔记';
        if (noteId) noteId.value = '';
        if (noteTitle) noteId.value = '';
        if (noteContent) noteContent.value = '';
    }

    modal.classList.add('show');
}

function closeNoteForm() {
    const modal = document.getElementById('modal-note');
    if (modal) {
        modal.classList.remove('show');
    }
}

async function saveNote() {
    const id = document.getElementById('note-id')?.value;
    const title = document.getElementById('note-title')?.value?.trim();
    const content = document.getElementById('note-content')?.value?.trim();

    if (!title) {
        alert('请输入标题');
        return;
    }

    try {
        const data = { title, content };
        let response;

        if (id) {
            response = await fetch(`${API_BASE}/articles/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
        } else {
            response = await fetch(`${API_BASE}/articles`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
        }

        const result = await response.json();
        if (result.success) {
            closeNoteForm();
        } else {
            alert(result.message || '操作失败');
        }
    } catch (error) {
        console.error('保存笔记失败:', error);
        alert('保存失败');
    }
}

function initDragAndDrop() {
    const dashboard = document.getElementById('dashboard');
    if (!dashboard) return;

    let draggedCard = null;

    const cards = document.querySelectorAll('.dashboard-card');
    cards.forEach(card => {
        card.addEventListener('dragstart', function(e) {
            draggedCard = card;
            card.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', card.dataset.id);
            e.dataTransfer.setData('text/html', card.outerHTML);
        });

        card.addEventListener('dragend', function(e) {
            card.classList.remove('dragging');
            draggedCard = null;
            document.querySelectorAll('.drop-indicator').forEach(el => el.remove());
        });

        const innerElements = card.querySelectorAll('*');
        innerElements.forEach(el => {
            el.setAttribute('draggable', 'false');
            el.addEventListener('dragstart', function(e) {
                e.stopPropagation();
            });
        });
    });

    dashboard.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        
        document.querySelectorAll('.drop-indicator').forEach(el => el.remove());
        
        const targetCard = e.target.closest('.dashboard-card');
        
        if (targetCard && targetCard !== draggedCard) {
            const targetRect = targetCard.getBoundingClientRect();
            const isTopHalf = (e.clientY - targetRect.top) < (targetRect.height / 2);
            
            const indicator = document.createElement('div');
            indicator.className = 'drop-indicator';
            
            if (isTopHalf) {
                targetCard.before(indicator);
            } else {
                targetCard.after(indicator);
            }
        }
    });

    dashboard.addEventListener('drop', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        if (!draggedCard) return;
        
        const targetCard = e.target.closest('.dashboard-card');
        const indicator = document.querySelector('.drop-indicator');
        
        if (indicator) {
            indicator.before(draggedCard);
            indicator.remove();
        } else if (targetCard && targetCard !== draggedCard) {
            const targetRect = targetCard.getBoundingClientRect();
            const isTopHalf = (e.clientY - targetRect.top) < (targetRect.height / 2);
            
            if (isTopHalf) {
                targetCard.before(draggedCard);
            } else {
                targetCard.after(draggedCard);
            }
        } else {
            dashboard.appendChild(draggedCard);
        }
        
        draggedCard.classList.remove('dragging');
        draggedCard = null;
        
        saveLayout();
    });

    dashboard.addEventListener('dragenter', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
    });
}

function initResizeCards() {
    const cards = document.querySelectorAll('.dashboard-card');
    cards.forEach(card => {
        const cardId = card.dataset.id;
        if (!cardId) return;

        // 设置整个卡片可拖拽
        card.setAttribute('draggable', 'true');

        initCardMenu(card, cardId);
        initCardResizeHandles(card);
    });

    document.addEventListener('click', function(e) {
        if (!e.target.closest('.card-menu-container') && !e.target.closest('.card-menu-btn')) {
            closeCardMenus();
        }
    });
}

function initCardMenu(card, cardId) {
    // 检查是否已经有菜单按钮，如果有则跳过（避免重复）
    const existingMenu = card.querySelector('.card-menu-container');
    if (existingMenu) {
        return;
    }
    
    const header = card.querySelector('.card-header');
    if (!header) return;

    const menuHTML = `
        <div class="card-menu-container">
            <button class="card-menu-btn" onclick="toggleCardMenu('${cardId}')"><img src="/static/emoji/more.png" class="emoji-icon" /></button>
            <div class="card-menu-dropdown" id="menu-${cardId}">
                ${getMenuOptions(cardId)}
            </div>
        </div>
    `;
    header.insertAdjacentHTML('beforeend', menuHTML);
}

function getMenuOptions(cardId) {
    const sizeOptions = ['1x1', '2x1', '1x2', '2x2'];
    let options = '';
    
    if (cardId === 'article-stars') {
        options += '<button onclick="toggleStarView()">列表视图</button>';
    } else if (cardId === 'subject-stars') {
        options += '<button onclick="toggleSubjectView()">列表视图</button>';
    } else if (cardId === 'word-stat') {
        options += '<button onclick="loadWordLine()">刷新图表</button>';
        options += '<button onclick="showWordsInfo()">统计信息</button>';
    } else if (cardId === 'heatmap') {
        options += '<button onclick="loadHeatmap()">刷新图表</button>';
    }
    
    sizeOptions.forEach(size => {
        options += `<button onclick="resizeCard('${cardId}', '${size}')">${size}</button>`;
    });
    
    return options;
}

function toggleCardMenu(cardId) {
    // 先关闭所有其他菜单
    closeCardMenus();
    // 然后切换当前菜单
    const menu = document.getElementById(`menu-${cardId}`);
    if (menu) {
        menu.classList.toggle('show');
    }
}

function closeCardMenus() {
    document.querySelectorAll('.card-menu-dropdown').forEach(menu => {
        menu.classList.remove('show');
    });
}

function initCardResizeHandles(card) {
    const resizeHandles = `
        <div class="card-resize-handle"></div>
        <div class="card-resize-handle-right"></div>
        <div class="card-resize-handle-bottom"></div>
    `;
    card.insertAdjacentHTML('beforeend', resizeHandles);

    initMouseResize(card);
}

function initMouseResize(card) {
    const cardId = card.dataset.id;
    const handle = card.querySelector('.card-resize-handle');
    const handleRight = card.querySelector('.card-resize-handle-right');
    const handleBottom = card.querySelector('.card-resize-handle-bottom');

    const startResize = (e, direction) => {
        e.preventDefault();
        const dashboard = document.getElementById('dashboard');
        const gridGap = parseInt(getComputedStyle(dashboard).gap);
        const cardWidth = card.offsetWidth;
        const cardHeight = card.offsetHeight;
        const startX = e.clientX;
        const startY = e.clientY;

        // 定义允许的固定尺寸 (列数 x 行数)
        const allowedSizes = ['1x1', '2x1', '1x2', '2x2', '3x1', '1x3'];
        
        // 获取网格单元格的基础尺寸
        const gridTemplateColumns = getComputedStyle(dashboard).gridTemplateColumns;
        const cellWidth = parseFloat(gridTemplateColumns.split('px')[0]) || 200;
        const cellHeight = parseFloat(getComputedStyle(dashboard).gridTemplateRows.split('px')[0]) || 200;

        const onMouseMove = (e) => {
            let newWidth = cardWidth + (e.clientX - startX);
            let newHeight = cardHeight + (e.clientY - startY);

            if (direction === 'right' || direction === 'corner') {
                card.style.width = Math.max(cellWidth, newWidth) + 'px';
            }
            if (direction === 'bottom' || direction === 'corner') {
                card.style.height = Math.max(cellHeight, newHeight) + 'px';
            }
        };

        const onMouseUp = () => {
            document.removeEventListener('mousemove', onMouseMove);
            document.removeEventListener('mouseup', onMouseUp);
            
            // 计算当前卡片尺寸对应的网格单元数
            const currentWidth = card.offsetWidth;
            const currentHeight = card.offsetHeight;
            
            const cols = Math.round(currentWidth / cellWidth);
            const rows = Math.round(currentHeight / cellHeight);
            
            // 确保在允许范围内
            const finalCols = Math.max(1, Math.min(3, cols));
            const finalRows = Math.max(1, Math.min(3, rows));
            
            // 构建尺寸字符串
            const newSize = `${finalCols}x${finalRows}`;
            
            // 如果是允许的尺寸，则应用
            if (allowedSizes.includes(newSize)) {
                resizeCard(cardId, newSize);
            } else {
                // 否则选择最接近的允许尺寸
                const closestSize = allowedSizes.reduce((prev, curr) => {
                    const [prevCols, prevRows] = prev.split('x').map(Number);
                    const [currCols, currRows] = curr.split('x').map(Number);
                    const prevDiff = Math.abs(prevCols - finalCols) + Math.abs(prevRows - finalRows);
                    const currDiff = Math.abs(currCols - finalCols) + Math.abs(currRows - finalRows);
                    return currDiff < prevDiff ? curr : prev;
                });
                resizeCard(cardId, closestSize);
            }
        };

        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mouseup', onMouseUp);
    };

    if (handle) {
        handle.addEventListener('mousedown', (e) => startResize(e, 'corner'));
    }
    if (handleRight) {
        handleRight.addEventListener('mousedown', (e) => startResize(e, 'right'));
    }
    if (handleBottom) {
        handleBottom.addEventListener('mousedown', (e) => startResize(e, 'bottom'));
    }
}

function resizeCard(cardId, newSize) {
    const card = document.querySelector(`[data-id="${cardId}"]`);
    if (!card) return;

    card.dataset.size = newSize;
    const [cols, rows] = newSize.split('x').map(Number);
    card.style.gridColumn = `span ${cols}`;
    card.style.gridRow = `span ${rows}`;
    card.style.width = '';
    card.style.height = '';

    // 自动保存布局
    saveLayout();

    const menu = document.getElementById(`menu-${cardId}`);
    if (menu) {
        menu.classList.remove('show');
    }
}



function selectCityFromSettings(city) {
    const cityInput = document.getElementById('city-input');
    if (cityInput) {
        cityInput.value = city;
    }
    
    // 更新设置页面中的城市显示
    const currentCityValue = document.getElementById('current-city-value');
    if (currentCityValue) {
        currentCityValue.textContent = city;
    }
    
    // 更新天气区域显示
    const cityEl = document.getElementById('current-city');
    if (cityEl) {
        cityEl.textContent = city;
    }
    localStorage.setItem('blossom-city', city);
    loadQWeather();
    
    // 关闭城市选项
    const cityOptions = document.getElementById('city-options');
    if (cityOptions) {
        cityOptions.classList.remove('show');
    }
}

// 初始化设置页面
function initSettingsPage() {
    // 设置页面左侧分类切换
    const settingSections = document.querySelectorAll('.settings-menu-item');
    settingSections.forEach(section => {
        section.addEventListener('click', () => {
            // 移除所有active状态
            settingSections.forEach(s => s.classList.remove('active'));
            // 添加当前active状态
            section.classList.add('active');
            
            // 切换内容区域
            const settingName = section.dataset.setting;
            const contentSections = document.querySelectorAll('.setting-content-section');
            contentSections.forEach(cs => {
                cs.style.display = 'none';
            });
            document.getElementById(`setting-${settingName}`).style.display = 'block';
        });
    });
    
    // 初始化主题选择
    const themeCards = document.querySelectorAll('.theme-card');
    themeCards.forEach(card => {
        card.addEventListener('click', () => {
            const theme = card.dataset.theme;
            setTheme(theme);
        });
    });
    
    // 初始化城市显示
    const savedCity = localStorage.getItem('blossom-city') || '北京';
    const cityDisplay = document.getElementById('city-display');
    if (cityDisplay) {
        cityDisplay.textContent = savedCity;
    }
    
    // 城市选择
    const cityButtons = document.querySelectorAll('.city-btn');
    cityButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const city = btn.dataset.city;
            localStorage.setItem('blossom-city', city);
            if (cityDisplay) {
                cityDisplay.textContent = city;
            }
            // 更新天气
            loadWeather(city);
            // 更新按钮状态
            cityButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        });
        // 设置当前城市按钮为active
        if (btn.dataset.city === savedCity) {
            btn.classList.add('active');
        }
    });
    
    // 初始化路径设置
    initPathSettings();
}


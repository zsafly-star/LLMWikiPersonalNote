    'fa-user-circle', 'fa-user', 'fa-user-alt', 'fa-user-check',
    'fa-smile', 'fa-smile-beam', 'fa-grin', 'fa-grin-beam',
    'fa-heart', 'fa-star', 'fa-sun', 'fa-moon',
    'fa-cloud', 'fa-brain', 'fa-cat', 'fa-dog',
    'fa-paw', 'fa-coffee', 'fa-music', 'fa-book',
    'fa-laptop', 'fa-phone', 'fa-camera', 'fa-gift',
    'fa-flower2', 'fa-leaf', 'fa-tree', 'fa-mountain',
    'fa-anchor', 'fa-ship', 'fa-plane', 'fa-car'
];

function loadAvatar() {
    const savedAvatar = localStorage.getItem('blossom-avatar');
    const avatarIcon = document.getElementById('avatar-icon');
    if (avatarIcon) {
        avatarIcon.className = `fas ${savedAvatar || 'fa-user-circle'} avatar-icon`;
    }
    
    const sidebarAvatar = document.getElementById('sidebar-avatar');
    if (sidebarAvatar) {
        sidebarAvatar.src = '/static/emoji/' + (savedAvatar || 'smiling_face_3d.png');
    }
}

function loadUsername() {
    const savedUsername = localStorage.getItem('blossom-username');
    const usernameEl = document.getElementById('user-name');
    if (usernameEl) {
        usernameEl.textContent = savedUsername || '用户';
    }
}

function changeAvatar() {
    const modal = document.getElementById('modal-avatar');
    if (!modal) {
        createAvatarModal();
    } else {
        modal.classList.add('show');
    }
}

function createAvatarModal() {
    const modal = document.createElement('div');
    modal.id = 'modal-avatar';
    modal.className = 'modal';
    modal.innerHTML = `
        <div class="modal-content avatar-modal">
            <div class="modal-header">
                <h3>选择头像图标</h3>
                <button class="btn-close" onclick="closeAvatarModal()" title="关闭">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="modal-body avatar-grid">
                ${avatarOptions.map(icon => `
                    <div class="avatar-option" onclick="selectAvatar('${icon}')">
                        <i class="fas ${icon}"></i>
                    </div>
                `).join('')}
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" onclick="closeAvatarModal()">确定</button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
    modal.classList.add('show');
}

function selectAvatar(iconName) {
    const avatarIcon = document.getElementById('avatar-icon');
    if (avatarIcon) {
        avatarIcon.className = `fas ${iconName} avatar-icon`;
    }
    localStorage.setItem('blossom-avatar', iconName);
    closeAvatarModal();
}

function closeAvatarModal() {
    const modal = document.getElementById('modal-avatar');
    if (modal) {
        modal.classList.remove('show');
    }
}

function initCharts() {
    const wordChartCtx = document.getElementById('wordChart');
    if (wordChartCtx) {
        new Chart(wordChartCtx, {
            type: 'line',
            data: {
                labels: Array.from({ length: 36 }, (_, i) => `${(i % 12) + 1}月`),
                datasets: [{
                    label: '字数',
                    data: [1200, 1900, 3000, 5000, 2000, 3000, 4500, 4000, 3500, 5000, 6000, 5500,
                           2200, 2900, 4000, 6000, 3000, 4000, 5500, 5000, 4500, 6000, 7000, 6500,
                           3200, 3900, 5000, 7000, 4000, 5000, 6500, 6000, 5500, 7000, 8000, 7500],
                    borderColor: '#0D9488',
                    backgroundColor: 'rgba(13, 148, 136, 0.1)',
                    borderWidth: 2,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 0,
                    pointHoverRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: { display: false },
                    y: { display: false }
                },
                interaction: {
                    intersect: false,
                    mode: 'index'
                }
            }
        });
    }

    const heatmapChartCtx = document.getElementById('heatmapChart');
    if (heatmapChartCtx) {
        const hours = ['00:00', '04:00', '08:00', '12:00', '16:00', '20:00'];
        const days = ['周一', '周二', '周三', '周四', '周五', '周六', '周日'];
        const data = [
            [2, 5, 8, 12, 15, 8],
            [3, 7, 10, 14, 18, 10],
            [5, 9, 12, 16, 20, 12],
            [4, 8, 11, 15, 19, 11],
            [6, 10, 13, 17, 22, 14],
            [8, 12, 15, 18, 15, 8],
            [5, 7, 9, 11, 8, 4]
        ];

        const flatData = [];
        const labels = [];
        data.forEach((row, dayIndex) => {
            row.forEach((value, hourIndex) => {
                for (let i = 0; i < value; i++) {
                    flatData.push({ x: hourIndex, y: dayIndex, value: value });
                }
            });
        });

        new Chart(heatmapChartCtx, {
            type: 'bar',
            data: {
                labels: hours,
                datasets: days.map((day, dayIndex) => ({
                    label: day,
                    data: data[dayIndex],
                    backgroundColor: data[dayIndex].map(v => 
                        `rgba(13, 148, 136, ${Math.min(v / 25, 1)})`
                    ),
                    borderRadius: 2,
                    barThickness: 18
                }))
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 10 }, color: '#999' }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { display: false }
                    }
                }
            }
        });
    }
}

function initNavigation() {
    const menuItems = document.querySelectorAll('.item-menu');
    menuItems.forEach(item => {
        item.addEventListener('click', function() {
            const view = this.dataset.view;
            switchView(view);
        });
    });
}

function switchView(view) {
    currentView = view;

    document.querySelectorAll('.item-menu').forEach(item => {
        item.classList.remove('is-active');
    });
    const activeMenu = document.querySelector(`[data-view="${view}"]`);
    if (activeMenu) {
        activeMenu.classList.add('is-active');
    }

    document.querySelectorAll('.view').forEach(v => {
        v.classList.remove('active');
    });
    const activeView = document.getElementById(`view-${view}`);
    if (activeView) {
        activeView.classList.add('active');
    }
    
    // 如果切换到图片视图，加载图片列表
    if (view === 'picture') {
        loadImages();
    }
}

// 加载图片列表
function loadImages() {
    const imageGrid = document.getElementById('image-grid');
    
    if (!imageGrid) {
        return;
    }
    
    imageGrid.innerHTML = `
        <div style="display: flex; justify-content: center; align-items: center; padding: 40px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#909399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="emoji-spin"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
        </div>
    `;
    
    fetch('/api/picture/images')
        .then(response => response.json())
        .then(result => {
            if (!result || result.code !== 200 || !result.data || result.data.length === 0) {
                imageGrid.innerHTML = `
                    <div class="empty-state">
                        <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4"/><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5-4 4-3-3"/></svg>
                        <p>${result?.message || '该路径下没有图片'}</p>
                    </div>
                `;
                return;
            }
            
            // 按文件夹分组
            const groupedImages = {};
            result.data.forEach(img => {
                const folder = img.folder || '根目录';
                if (!groupedImages[folder]) {
                    groupedImages[folder] = [];
                }
                groupedImages[folder].push(img);
            });
            
            // 生成卡片HTML
            let html = '';
            Object.keys(groupedImages).forEach(folder => {
                html += `
                    <div class="image-folder">
                        <div class="folder-header">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 20h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z"/><path d="M14 2v4"/><path d="M2 14h4"/></svg>
                            <span>${folder}</span>
                            <span class="image-count">${groupedImages[folder].length} 张图片</span>
                        </div>
                        <div class="image-grid">
                `;
                
                groupedImages[folder].forEach(img => {
                    const imgUrl = `/api/picture/image?img=${encodeURIComponent(img.path)}`;
                    const size = formatFileSize(img.size);
                    const date = formatDate(img.modified);
                    
                    html += `
                        <div class="image-card" data-path="${img.path}">
                            <div class="image-preview">
                                <img src="${imgUrl}" alt="${img.name}" loading="lazy">
                            </div>
                            <div class="image-info">
                                <span class="image-name">${img.name}</span>
                                <span class="image-meta">${size} · ${date}</span>
                            </div>
                        </div>
                    `;
                });
                
                html += `
                        </div>
                    </div>
                `;
            });
            
            imageGrid.innerHTML = html;
        })
        .catch(error => {
            console.error('Failed to load images:', error);
            imageGrid.innerHTML = `
                <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4"/><path d="M12 9v4"/><path d="M12 17h.01"/><circle cx="12" cy="12" r="10"/></svg>
                    <p>加载图片失败，请检查路径配置</p>
                </div>
            `;
        });
}

// 格式化文件大小
function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

// 格式化日期
function formatDate(timestamp) {
    const date = new Date(timestamp * 1000);
    return date.toLocaleDateString('zh-CN');
}

